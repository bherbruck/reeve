# .env.example — copy to .env and fill in. Shape only; never commit .env.
# reeve-server reads these (crates/reeve-server/src/config.rs). Unset =>
# the compose.yml default applies. Values here are DEFAULTS/EXAMPLES.

# --- image / port -----------------------------------------------------
# REEVE_IMAGE=ghcr.io/beigesys/reeve-server:latest   # or leave to `build:`
# REEVE_PORT=8420                                  # host port -> :8420

# --- auth (D1) --------------------------------------------------------
REEVE_AUTH=password                    # password | proxy | none
# proxy mode (fronting SSO proxy): both REQUIRED, refuses to start otherwise
# REEVE_PROXY_USER_HEADER=Remote-User
# REEVE_PROXY_ROLE_HEADER=Remote-Groups
# REEVE_PROXY_TRUSTED_CIDR=10.0.0.0/8,192.168.0.0/16
# REEVE_SESSION_TTL_SECS=604800          # password mode sliding idle TTL

# --- render (D8) ------------------------------------------------------
# The address devices reach THIS server on; substituted for
# ${REEVE_REGISTRY} in rendered compose files.
# REEVE_REGISTRY=reeve.example.com:8420

# --- tier / federation (D9 / REV-005) ---------------------------------
# Unset => root/hub (and the air-gapped mode). Set all three for a gateway.
# REEVE_UPSTREAM=https://hub.example.com
# REEVE_UPSTREAM_TOKEN=rvt_...            # scoped tier token from the hub
# REEVE_SITE=plant-a                      # the site layer this gateway owns
# REEVE_SYNC_INTERVAL_SECS=60

# --- durability (SPEC §9, all in-binary) ------------------------------
REEVE_DURABILITY=none                  # none | snapshot | changeset
# REEVE_DURABILITY_TARGET=s3://my-bucket/reeve   # or file:///data/snapshots
# REEVE_DURABILITY_INSTANCE=default
# REEVE_DURABILITY_SNAPSHOT_INTERVAL_SECS=900
# REEVE_DURABILITY_CHANGESET_INTERVAL_SECS=5
# REEVE_DURABILITY_VERIFY_INTERVAL_SECS=86400
# S3-compatible target credentials (MinIO/rustfs: set AWS_ENDPOINT):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT=http://minio:9000

# --- registry proxy (D8, --profile registry) --------------------------
# REEVE_ZOT_URL=http://registry:5000     # backend zot; device tokens
# REEVE_ZOT_USERNAME=                     # terminate here, Basic injected
# REEVE_ZOT_PASSWORD=                     # toward the backend

# --- bootstrap (§10.4, embedded-agents build) -------------------------
# REEVE_INSTALL_OPEN=1                    # open GET /install without a token
